# ─── Postgres ───────────────────────────────────────────
POSTGRES_USER=ozen_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ozen_lms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Backend ────────────────────────────────────────────
SECRET_KEY=change_me_very_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ─── Storage ─────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/storage
# S3 (fill when ready):
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── App ─────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
